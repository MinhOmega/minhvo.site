---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Services from '../components/Services.astro';
import Marquee from '../components/Marquee.astro';
import Works from '../components/Works.astro';
import About from '../components/About.astro';
import Testimonials from '../components/Testimonials.astro';
import Contact from '../components/Contact.astro';
import { SITE } from '../content/profile';

const title = `${SITE.fullName} — ${SITE.title}`;
const description = SITE.description;
---

<BaseLayout title={title} description={description} type="profile">
  <Hero />

  <!-- Dark sectional block: services + marquee + works -->
  <div class="relative rounded-t-3xl bg-[#0B0B0A] py-[5%] text-flax-smoke-200">
    <Services />
    <Marquee />
    <Works />
  </div>

  <About />
  <Testimonials />
  <Contact />
</BaseLayout>
