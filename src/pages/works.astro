---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE, PROJECTS } from '../content/profile';

const title = `Works — ${SITE.fullName}`;
const description = `Selected projects by ${SITE.fullName} — enterprise AI platforms, SaaS storefronts, dashboards, and mobile apps.`;
---

<BaseLayout title={title} description={description}>
  <section class="container-x pt-20 pb-12">
    <p class="text-sm uppercase tracking-[0.25em] text-[color:var(--color-muted)]">Works</p>
    <h1 class="mt-6 text-5xl sm:text-6xl">Selected projects.</h1>
    <p class="mt-8 max-w-2xl text-lg text-[color:var(--color-muted)]">
      Production systems shipped across enterprise AI, SaaS, and consumer mobile.
    </p>
  </section>

  <section class="container-x pb-20 border-t hairline pt-4">
    {PROJECTS.map((p, i) => (
      <article class={`py-10 ${i > 0 ? 'border-t hairline' : ''}`}>
        <div class="grid sm:grid-cols-[1fr_220px] gap-6">
          <div>
            <h2 class="font-serif text-3xl">{p.name}</h2>
            <p class="mt-1 text-sm text-[color:var(--color-muted)]">{p.org} · {p.period}</p>
            <p class="mt-3 text-sm">{p.stack}</p>
            <ul class="mt-5 space-y-2 list-disc pl-5 text-[color:var(--color-muted)]">
              {p.bullets.map((b) => <li>{b}</li>)}
            </ul>
          </div>
          <div class="text-sm text-[color:var(--color-muted)]">
            <p class="uppercase tracking-[0.18em] text-xs">#0{i + 1}</p>
          </div>
        </div>
      </article>
    ))}
  </section>
</BaseLayout>
