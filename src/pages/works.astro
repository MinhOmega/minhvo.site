---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE, PROJECTS } from '../content/profile';

const title = `Works — ${SITE.fullName}`;
const description = `Selected projects by ${SITE.fullName} — enterprise AI platforms, SaaS storefronts, dashboards, and mobile apps.`;
---

<BaseLayout title={title} description={description}>
  <section class="padding-x pt-32 pb-12">
    <p class="text-xs uppercase tracking-[0.25em] text-flax-smoke-500">( Works )</p>
    <h1 class="reveal heading-1 mt-6 font-extrabold uppercase leading-none">Selected Projects /</h1>
    <p class="reveal heading-4 mt-10 max-w-[40ch] font-medium text-balance">
      Production systems shipped across enterprise AI, multi-tenant SaaS, and consumer mobile.
    </p>
  </section>

  <section class="padding-x pb-24 border-t hairline pt-12">
    {PROJECTS.map((p, i) => (
      <article class={`reveal grid sm:grid-cols-[120px_1fr_220px] gap-6 py-10 ${i > 0 ? 'border-t hairline' : ''}`}>
        <p class="font-mono text-sm text-flax-smoke-500">( 0{i + 1} )</p>
        <div>
          <h2 class="font-fancy text-3xl sm:text-4xl font-bold uppercase">{p.name}</h2>
          <p class="mt-1 text-sm text-flax-smoke-500">{p.org} · {p.period}</p>
          <p class="mt-3 text-sm font-medium">{p.stack}</p>
          <ul class="mt-5 space-y-2 list-disc pl-5 text-flax-smoke-700 max-w-[60ch]">
            {p.bullets.map((b) => <li>{b}</li>)}
          </ul>
        </div>
        <div class="flex flex-wrap gap-1.5 self-start">
          {p.stack.split('·').slice(0, 4).map((t) => (
            <span class="rounded-full border border-flax-smoke-500 px-3 py-1 text-xs uppercase text-flax-smoke-700">
              {t.trim()}
            </span>
          ))}
        </div>
      </article>
    ))}
  </section>
</BaseLayout>
