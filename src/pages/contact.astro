---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE, CONTACT } from '../content/profile';

const title = `Contact — ${SITE.fullName}`;
const description = `Get in touch with ${SITE.fullName} for engineering engagements, advisory, or collaboration.`;
---

<BaseLayout title={title} description={description}>
  <section class="container-x pt-20 pb-16">
    <p class="text-sm uppercase tracking-[0.25em] text-[color:var(--color-muted)]">Contact</p>
    <h1 class="mt-6 text-5xl sm:text-7xl">Let’s build something.</h1>
    <p class="mt-8 max-w-2xl text-lg text-[color:var(--color-muted)]">
      The fastest way to reach me is email. I read everything and reply within 24 hours on weekdays.
    </p>
  </section>

  <section class="container-x pb-20 border-t hairline pt-12 grid sm:grid-cols-2 gap-12">
    <div>
      <p class="text-sm uppercase tracking-[0.18em] text-[color:var(--color-muted)]">Email</p>
      <a
        href={`mailto:${CONTACT.email}`}
        class="mt-2 inline-block font-serif text-3xl link-underline"
      >
        {CONTACT.email}
      </a>
      <p class="mt-6 text-sm uppercase tracking-[0.18em] text-[color:var(--color-muted)]">Phone</p>
      <p class="mt-2 font-serif text-2xl">{CONTACT.phone}</p>
      <p class="mt-6 text-sm uppercase tracking-[0.18em] text-[color:var(--color-muted)]">Location</p>
      <p class="mt-2">{CONTACT.location}</p>
    </div>
    <div>
      <p class="text-sm uppercase tracking-[0.18em] text-[color:var(--color-muted)]">Elsewhere</p>
      <ul class="mt-4 space-y-3 text-lg">
        <li><a class="link-underline" href={CONTACT.github} rel="me noopener" target="_blank">GitHub →</a></li>
        <li><a class="link-underline" href={CONTACT.linkedin} rel="me noopener" target="_blank">LinkedIn →</a></li>
      </ul>
    </div>
  </section>
</BaseLayout>
