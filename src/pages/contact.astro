---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE, CONTACT } from '../content/profile';

const title = `Contact — ${SITE.fullName}`;
const description = `Get in touch with ${SITE.fullName} for engineering engagements, advisory, or collaboration.`;
---

<BaseLayout title={title} description={description}>
  <section class="padding-x pt-32 pb-16">
    <p class="text-xs uppercase tracking-[0.25em] text-flax-smoke-500">( Contact )</p>
    <h1 class="reveal heading-1 mt-6 font-extrabold uppercase leading-none">
      Let's build<br />something /
    </h1>
    <p class="reveal heading-4 mt-10 max-w-[40ch] font-medium text-balance">
      The fastest way to reach me is email. I read everything and reply within 24 hours on weekdays.
    </p>
  </section>

  <section class="padding-x pb-20 border-t hairline pt-14 grid sm:grid-cols-2 gap-12">
    <div>
      <p class="text-xs uppercase tracking-[0.18em] text-flax-smoke-500">Email</p>
      <a href={`mailto:${CONTACT.email}`} class="link-underline mt-2 inline-block font-fancy text-3xl">
        {CONTACT.email}
      </a>
      <p class="mt-6 text-xs uppercase tracking-[0.18em] text-flax-smoke-500">Phone</p>
      <p class="mt-2 font-fancy text-2xl">{CONTACT.phone}</p>
      <p class="mt-6 text-xs uppercase tracking-[0.18em] text-flax-smoke-500">Location</p>
      <p class="mt-2 font-fancy text-2xl">{CONTACT.location}</p>
    </div>
    <div>
      <p class="text-xs uppercase tracking-[0.18em] text-flax-smoke-500">Elsewhere</p>
      <ul class="mt-4 space-y-3 text-lg">
        <li><a class="link-underline" href={CONTACT.github} rel="me noopener" target="_blank">GitHub →</a></li>
        <li><a class="link-underline" href={CONTACT.linkedin} rel="me noopener" target="_blank">LinkedIn →</a></li>
      </ul>

      <div class="mt-10">
        <a href={`mailto:${CONTACT.email}`} class="btn-pill">
          <span class="btn-hover" aria-hidden="true">Get in touch</span>
          <span class="btn-label">Get in touch</span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
