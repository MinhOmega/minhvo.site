---
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  SITE,
  EXPERIENCE,
  SKILLS,
  EDUCATION,
  AWARDS,
} from '../content/profile';

const title = `About — ${SITE.fullName}`;
const description = `${SITE.fullName} — Software Engineer with 7 years of experience in enterprise SaaS and Gen AI platforms.`;
---

<BaseLayout title={title} description={description}>
  <section class="container-x pt-20 pb-12">
    <p class="text-sm uppercase tracking-[0.25em] text-[color:var(--color-muted)]">About</p>
    <h1 class="mt-6 text-5xl sm:text-6xl">Engineer. Architect. AI-Native.</h1>
    <p class="mt-8 max-w-2xl text-lg text-[color:var(--color-muted)]">
      I am {SITE.fullName} — a Software Engineer with seven years building production systems for global clients. My current focus: multi-tenant RAG, MCP-driven agents, and the cloud foundations that keep them reliable.
    </p>
  </section>

  <section class="container-x py-12 border-t hairline">
    <h2 class="text-3xl">Experience</h2>
    <div class="mt-10 space-y-12">
      {EXPERIENCE.map((e) => (
        <article class="grid sm:grid-cols-[200px_1fr] gap-6">
          <div>
            <p class="font-medium">{e.company}</p>
            <p class="text-sm text-[color:var(--color-muted)]">{e.period}</p>
          </div>
          <div>
            <p class="font-serif text-xl">{e.role}</p>
            <p class="text-sm text-[color:var(--color-muted)] mt-1">{e.stack}</p>
            <ul class="mt-4 space-y-2 list-disc pl-5 text-[color:var(--color-muted)]">
              {e.highlights.map((h) => <li>{h}</li>)}
            </ul>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="container-x py-12 border-t hairline">
    <h2 class="text-3xl">Skills</h2>
    <dl class="mt-8 grid sm:grid-cols-2 gap-x-12 gap-y-6">
      {Object.entries(SKILLS).map(([group, items]) => (
        <div>
          <dt class="text-sm uppercase tracking-[0.18em] text-[color:var(--color-muted)]">{group}</dt>
          <dd class="mt-2">{items.join(' · ')}</dd>
        </div>
      ))}
    </dl>
  </section>

  <section class="container-x py-12 border-t hairline grid sm:grid-cols-2 gap-12">
    <div>
      <h2 class="text-3xl">Education</h2>
      <p class="mt-6 font-serif text-xl">{EDUCATION.school}</p>
      <p class="text-[color:var(--color-muted)]">{EDUCATION.degree}</p>
      <p class="text-sm text-[color:var(--color-muted)]">{EDUCATION.period}</p>
    </div>
    <div>
      <h2 class="text-3xl">Awards</h2>
      <ul class="mt-6 space-y-3">
        {AWARDS.map((a) => (
          <li>
            <p class="font-serif text-xl">{a.name}</p>
            <p class="text-sm text-[color:var(--color-muted)]">{a.org} · {a.period}</p>
            <p class="text-[color:var(--color-muted)]">{a.note}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>
