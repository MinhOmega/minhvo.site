---
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  SITE,
  EXPERIENCE,
  SKILLS,
  EDUCATION,
  AWARDS,
} from '../content/profile';

const title = `About — ${SITE.fullName}`;
const description = `${SITE.fullName} — Software Engineer with 7 years of experience in enterprise SaaS and Gen AI platforms.`;
---

<BaseLayout title={title} description={description}>
  <section class="padding-x pt-32 pb-12">
    <p class="text-xs uppercase tracking-[0.25em] text-flax-smoke-500">( About )</p>
    <h1 class="reveal heading-1 mt-6 font-extrabold uppercase leading-none">
      Engineer. Architect.<br />AI-Native /
    </h1>
    <p class="reveal heading-4 mt-10 max-w-[40ch] font-medium text-balance">
      I am {SITE.fullName} — a Software Engineer with seven years building production systems for global clients. My current focus: multi-tenant RAG, MCP-driven agents, and the cloud foundations that keep them reliable.
    </p>
  </section>

  <section class="padding-x py-16 border-t hairline">
    <h2 class="heading-2 font-bold uppercase">Experience</h2>
    <div class="mt-12 space-y-12">
      {EXPERIENCE.map((e) => (
        <article class="grid sm:grid-cols-[220px_1fr] gap-6 border-b hairline pb-10">
          <div>
            <p class="font-fancy text-xl font-bold">{e.company}</p>
            <p class="text-sm text-flax-smoke-500">{e.period}</p>
          </div>
          <div>
            <p class="font-fancy text-2xl font-semibold">{e.role}</p>
            <p class="text-sm text-flax-smoke-500 mt-1">{e.stack}</p>
            <ul class="mt-4 space-y-2 list-disc pl-5 text-flax-smoke-700">
              {e.highlights.map((h) => <li>{h}</li>)}
            </ul>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="padding-x py-16 border-t hairline">
    <h2 class="heading-2 font-bold uppercase">Skills</h2>
    <dl class="mt-10 grid sm:grid-cols-2 gap-x-12 gap-y-8">
      {Object.entries(SKILLS).map(([group, items]) => (
        <div>
          <dt class="text-xs uppercase tracking-[0.18em] text-flax-smoke-500">( {group} )</dt>
          <dd class="mt-2 font-fancy text-lg">{items.join(' · ')}</dd>
        </div>
      ))}
    </dl>
  </section>

  <section class="padding-x py-16 border-t hairline grid sm:grid-cols-2 gap-12">
    <div>
      <h2 class="heading-2 font-bold uppercase">Education</h2>
      <p class="mt-6 font-fancy text-2xl">{EDUCATION.school}</p>
      <p class="text-flax-smoke-600">{EDUCATION.degree}</p>
      <p class="text-sm text-flax-smoke-500">{EDUCATION.period}</p>
    </div>
    <div>
      <h2 class="heading-2 font-bold uppercase">Awards</h2>
      <ul class="mt-6 space-y-4">
        {AWARDS.map((a) => (
          <li>
            <p class="font-fancy text-2xl">{a.name}</p>
            <p class="text-sm text-flax-smoke-500">{a.org} · {a.period}</p>
            <p class="text-flax-smoke-700">{a.note}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>
