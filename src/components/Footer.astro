---
import { CONTACT, SITE } from '../content/profile';

const menu = [
  { label: 'Home', url: '#hero' },
  { label: 'Services', url: '#services' },
  { label: 'Projects', url: '#works' },
  { label: 'About', url: '#about-me-section' },
  { label: 'Testimonials', url: '#testimonials-section' },
  { label: 'Contact', url: '#contact-section' },
];
const socials = [
  { label: 'GitHub', url: CONTACT.github },
  { label: 'LinkedIn', url: CONTACT.linkedin },
  { label: 'Email', url: `mailto:${CONTACT.email}` },
];
const resources = [
  { label: 'llms.txt', url: '/llms.txt' },
  { label: 'Sitemap', url: '/sitemap-index.xml' },
];

const year = new Date().getFullYear();
---

<footer class="relative flex flex-col items-center justify-center gap-16 px-[3%] py-[2%]">
  <div class="grid w-full grid-cols-2 gap-x-6 md:grid-cols-12">
    <div class="flex flex-col md:col-span-6">
      <p class="heading-5 w-full border-b border-flax-smoke-400 pb-2 font-bold">Menu</p>
      <ul class="mt-2 grid grid-cols-2 gap-y-1">
        {menu.map((l) => (
          <li class="heading-6">
            <a class="link-underline font-medium tracking-wide lowercase" href={l.url}>{l.label}</a>
          </li>
        ))}
      </ul>
    </div>
    <div class="mt-6 flex flex-col md:col-span-3 md:mt-0">
      <p class="heading-5 w-full border-b border-flax-smoke-400 pb-2 font-bold">Socials</p>
      <ul class="mt-2 space-y-1">
        {socials.map((l) => (
          <li class="heading-6">
            <a class="link-underline font-medium tracking-wide lowercase" target="_blank" rel="me noopener" href={l.url}>{l.label}</a>
          </li>
        ))}
      </ul>
    </div>
    <div class="mt-6 flex flex-col md:col-span-3 md:mt-0">
      <p class="heading-5 w-full border-b border-flax-smoke-400 pb-2 font-bold">Resources</p>
      <ul class="mt-2 space-y-1">
        {resources.map((l) => (
          <li class="heading-6">
            <a class="link-underline font-medium tracking-wide lowercase" href={l.url}>{l.label}</a>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <div class="grid w-full grid-cols-12 items-center gap-4">
    <div class="col-span-7 md:col-span-6">
      <h6 class="heading-4 sm:heading-2 leading-none font-bold">
        &copy; {year} {SITE.name} <br />
        All rights reserved.
      </h6>
    </div>

    <div class="col-span-5 md:col-span-3">
      <p class="heading-6 font-bold uppercase">My local time</p>
      <p class="heading-6" id="my-local-time">—</p>
      <p class="heading-6 mt-2 font-bold uppercase">Your local time</p>
      <p class="heading-6" id="user-local-time">—</p>
    </div>

    <div class="hidden md:col-span-2 md:col-start-11 md:block lg:col-span-1 lg:col-start-12">
      <a
        href="#hero"
        id="scroll-to-top"
        class="flex-center size-16 cursor-pointer rounded-full bg-flax-smoke-400 lg:size-20"
        aria-label="Scroll to top"
      >
        <svg
          class="size-1/2"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
        >
          <path d="M12 4L12 20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          <path d="M16.9998 8.99996C16.9998 8.99996 13.3174 4.00001 11.9998 4C10.6822 3.99999 6.99982 9 6.99982 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    </div>
  </div>
</footer>

<script>
  function fmt(d: Date, tz?: string) {
    return new Intl.DateTimeFormat('en-US', {
      hour: 'numeric', minute: '2-digit', second: '2-digit', hour12: true,
      timeZone: tz,
    }).format(d);
  }
  const myEl = document.getElementById('my-local-time');
  const userEl = document.getElementById('user-local-time');
  function tick() {
    const now = new Date();
    if (myEl) myEl.textContent = fmt(now, 'Asia/Ho_Chi_Minh');
    if (userEl) userEl.textContent = fmt(now);
  }
  tick();
  setInterval(tick, 1000);
</script>
