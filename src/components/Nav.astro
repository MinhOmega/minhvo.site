---
import { NAV, SITE } from '../content/profile';

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header class="border-b hairline">
  <div class="container-x flex items-center justify-between h-16">
    <a href="/" class="font-serif text-xl tracking-tight">
      {SITE.name}<span class="text-[color:var(--color-accent)]">.</span>
    </a>
    <nav aria-label="Primary">
      <ul class="flex items-center gap-6 text-sm">
        {NAV.map((item) => {
          const itemPath = item.href.replace(/\/$/, '') || '/';
          const isActive = path === itemPath;
          return (
            <li>
              <a
                href={item.href}
                class={`link-underline ${isActive ? 'text-[color:var(--color-ink)]' : 'text-[color:var(--color-muted)]'}`}
                aria-current={isActive ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          );
        })}
      </ul>
    </nav>
  </div>
</header>
